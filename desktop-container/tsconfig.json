{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "bun-types"],
    "paths": {
      "@/*": ["../src/*"],
      "@desktop/*": ["../desktop/renderer/src/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "../desktop/shared/**/*.ts"
  ],
  "exclude": [
    "./.local-dev/**/*",
    "./backend/extensions/**/*",
    "./vendor/**/*"
  ]
}
