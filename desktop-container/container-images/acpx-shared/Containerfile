FROM node:22-bookworm-slim

ARG ACPX_VERSION=latest
ARG CODEX_VERSION=latest
ARG CLAUDE_VERSION=latest

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g \
  acpx@${ACPX_VERSION} \
  @anthropic-ai/claude-code@${CLAUDE_VERSION} \
  @openai/codex@${CODEX_VERSION}

COPY acpx-shared/entrypoint.sh /usr/local/bin/desktop-entrypoint.sh
COPY bridge/acon-host-bridge.mjs /usr/local/lib/acon/acon-host-bridge.mjs
COPY bridge/acon-mcp.mjs /usr/local/lib/acon/acon-mcp.mjs
RUN chmod +x \
    /usr/local/bin/desktop-entrypoint.sh \
    /usr/local/lib/acon/acon-host-bridge.mjs \
    /usr/local/lib/acon/acon-mcp.mjs \
  && ln -sf /usr/local/lib/acon/acon-host-bridge.mjs /usr/local/bin/acon-host-bridge \
  && ln -sf /usr/local/lib/acon/acon-mcp.mjs /usr/local/bin/acon-mcp

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/desktop-entrypoint.sh"]
