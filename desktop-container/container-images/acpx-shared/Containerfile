FROM node:22-bookworm

RUN mkdir -p /opt/acon/npm-global /usr/local/lib/acon

COPY vendor/npm-global/ /opt/acon/npm-global/

COPY acpx-shared/entrypoint.sh /usr/local/bin/desktop-entrypoint.sh
COPY bridge/acon-agentd.mjs /usr/local/lib/acon/acon-agentd.mjs
COPY bridge/acon-mcp.mjs /usr/local/lib/acon/acon-mcp.mjs
RUN chmod +x \
    /usr/local/bin/desktop-entrypoint.sh \
    /usr/local/lib/acon/acon-agentd.mjs \
    /usr/local/lib/acon/acon-mcp.mjs \
  && printf '%s\n' '#!/bin/sh' 'exec node /opt/acon/npm-global/node_modules/@anthropic-ai/claude-code/cli.js "$@"' > /usr/local/bin/claude \
  && printf '%s\n' '#!/bin/sh' 'exec node /opt/acon/npm-global/node_modules/@openai/codex/bin/codex.js "$@"' > /usr/local/bin/codex \
  && chmod +x /usr/local/bin/claude /usr/local/bin/codex \
  && ln -sf /usr/local/lib/acon/acon-agentd.mjs /usr/local/bin/acon-agentd \
  && ln -sf /usr/local/lib/acon/acon-mcp.mjs /usr/local/bin/acon-mcp

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/desktop-entrypoint.sh"]
