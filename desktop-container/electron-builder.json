{
  "appId": "ai.camel.acon",
  "productName": "Super Camel",
  "asar": true,
  "afterSign": "desktop-container/scripts/notarize.mjs",
  "directories": {
    "output": "dist/bundle"
  },
  "files": [
    "package.json",
    "desktop/electron/**/*",
    "desktop-container/electron/**/*"
  ],
  "extraResources": [
    {
      "from": "desktop-container/.local/bundle/resources/desktop",
      "to": "desktop",
      "filter": [
        "**/*"
      ]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "gatekeeperAssess": false,
    "hardenedRuntime": true,
    "icon": "desktop-container/assets/super-camel.icns",
    "entitlements": "desktop-container/entitlements.mac.plist",
    "entitlementsInherit": "desktop-container/entitlements.mac.inherit.plist",
    "target": [
      {
        "target": "dir",
        "arch": [
          "arm64"
        ]
      }
    ]
  }
}
