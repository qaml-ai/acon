FROM node:22-bookworm-slim

ARG ACPX_VERSION=0.5.1
ARG CLAUDE_VERSION=2.1.92

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g acpx@${ACPX_VERSION} @anthropic-ai/claude-code@${CLAUDE_VERSION}

COPY entrypoint.sh /usr/local/bin/poc-entrypoint.sh
RUN chmod +x /usr/local/bin/poc-entrypoint.sh

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/poc-entrypoint.sh"]
CMD ["acpx", "--format", "json", "--approve-all", "--cwd", "/workspace", "claude", "exec", "--file", "-"]
