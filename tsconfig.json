{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "vite/client", "bun-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@desktop/*": ["./desktop/renderer/src/*"]
    }
  },
  "include": ["desktop/**/*.ts", "desktop/**/*.tsx", "desktop-container/**/*.ts", "desktop-container/**/*.tsx", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
  "exclude": ["node_modules", "dist", "build"]
}
