{
  "name": "acon",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.4",
  "type": "module",
  "main": "desktop-container/electron/main.mjs",
  "scripts": {
    "renderer": "bun x vite --config desktop/vite.config.ts",
    "build": "bun run build:renderer",
    "build:renderer": "bun x vite build --config desktop/vite.config.ts",
    "build:bundle": "node desktop-container/scripts/build-bundle.mjs",
    "check": "bun run check:backend && bun run check:renderer",
    "check:backend": "bun x tsc -p desktop-container/tsconfig.json --noEmit",
    "check:renderer": "bun x tsc -p desktop/tsconfig.json --noEmit",
    "dev": "node desktop-container/scripts/dev.mjs",
    "prepare:container": "node desktop-container/scripts/prepare-container-assets.mjs",
    "backend": "node --import tsx/esm desktop-container/scripts/backend-smoke.mjs",
    "probe:claude": "DESKTOP_PROVIDER_OVERRIDE=claude node desktop-container/scripts/probe-turn.mjs",
    "probe:codex": "DESKTOP_PROVIDER_OVERRIDE=codex node desktop-container/scripts/probe-turn.mjs",
    "probe": "node desktop-container/scripts/probe-turn.mjs",
    "start": "NODE_OPTIONS='--import tsx/esm' bun x electron desktop-container/electron/main.mjs",
    "test:integration": "RUN_DESKTOP_CONTAINER_INTEGRATION=1 bun x vitest run tests/desktop-container-acpx.integration.test.ts",
    "test": "bun x vitest",
    "test:run": "bun x vitest run",
    "test:renderer": "bun x vitest run tests/desktop-container-app-streaming.test.tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.1.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.20.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.27",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "bun-types": "^1.3.4",
    "electron": "^37.2.6",
    "electron-builder": "26.8.1",
    "eslint": "^9",
    "jsdom": "^27.3.0",
    "png-to-ico": "^3.0.1",
    "shadcn": "^3.6.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "8.0.0-beta.16",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "vite": "$vite"
  }
}
